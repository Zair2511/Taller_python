from math import sqrt

class FormulaGeneral:
    def __init__(self,a:float,b:float,c:float):
        self.a=a
        self.b=b   
        self.c=c


    def evaluar(self)->tuple:  
        x1:float= -self.b + sqrt(self.b**2 - 4*self.a*self.c) / (2*self.a)
        x2:float= -self.b - sqrt(self.b**2 - 4*self.a*self.c) / (2*self.a)
        
        return(x1,x2) 

if __name__ == "__main__":
        fg=FormulaGeneral(1,-3,2)
        x1,x2=fg.evaluar()

        print(x1)
        print(x2)